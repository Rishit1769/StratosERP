generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Subject {
  subjectId      Int     @id @default(autoincrement()) @map("subject_id")
  name           String  @db.VarChar(100)
  semesterLevel  Int     @map("semester_level")
  hasLab         Boolean @default(false) @map("has_lab")
  labMarksWeight Int?    @map("lab_marks_weight")

  @@map("subject")
}

model GlobalConfig {
  configId           Int      @id @default(autoincrement()) @map("config_id")
  activeSemesterType String   @map("active_semester_type") @db.VarChar(4)
  startDate          DateTime @map("start_date") @db.Date
  endDate            DateTime @map("end_date") @db.Date

  @@map("global_config")
}

model Faculty {
  facultyId       Int     @id @default(autoincrement()) @map("faculty_id")
  name            String  @db.VarChar(100)
  emailId         String  @unique(map: "email_id") @map("email_id") @db.VarChar(150)
  designationRole String  @map("designation_role") @db.VarChar(30)
  passwordHash    String  @default("") @map("password_hash") @db.VarChar(255)
  isHod           Boolean @default(false) @map("is_hod")

  @@map("faculty")
}

model AdminUser {
  adminId      Int    @id @default(autoincrement()) @map("admin_id")
  name         String @db.VarChar(100)
  emailId      String @unique(map: "email_id") @map("email_id") @db.VarChar(150)
  passwordHash String @map("password_hash") @db.VarChar(255)

  @@map("admin_user")
}

model Student {
  uid             String @id @db.VarChar(30)
  emailId         String @unique(map: "email_id") @map("email_id") @db.VarChar(150)
  currentSemester Int    @map("current_semester")
  academicYear    String @map("academic_year") @db.VarChar(10)
  passwordHash    String @default("") @map("password_hash") @db.VarChar(255)

  @@map("student")
}

model StudentSubjectRecord {
  studentUid String   @map("student_uid") @db.VarChar(30)
  subjectId  Int      @map("subject_id")
  status     String   @db.VarChar(10)
  marks      Decimal? @db.Decimal(5, 2)

  @@id([studentUid, subjectId])
  @@index([studentUid], map: "idx_ssr_student")
  @@index([subjectId], map: "idx_ssr_subject")
  @@map("student_subject_record")
}

model TimetableSlot {
  slotId    Int      @id @default(autoincrement()) @map("slot_id")
  dayOfWeek String   @map("day_of_week") @db.VarChar(10)
  startTime DateTime @map("start_time") @db.Time(0)
  endTime   DateTime @map("end_time") @db.Time(0)
  subjectId Int      @map("subject_id")
  facultyId Int      @map("faculty_id")

  @@index([facultyId], map: "idx_slot_faculty")
  @@index([subjectId], map: "idx_slot_subject")
  @@map("timetable_slot")
}

model LectureLog {
  logId                  Int      @id @default(autoincrement()) @map("log_id")
  slotId                 Int      @map("slot_id")
  syllabusTopicsTaught   String?  @map("syllabus_topics_taught") @db.Text
  additionalTopicsTaught String?  @map("additional_topics_taught") @db.Text
  executionDate          DateTime @map("execution_date") @db.Date

  @@unique([slotId, executionDate], map: "uq_log_slot_date")
  @@index([slotId], map: "idx_log_slot")
  @@index([executionDate], map: "idx_log_date")
  @@map("lecture_log")
}

model GrievanceTicket {
  ticketId            Int      @id @default(autoincrement()) @map("ticket_id")
  studentUid          String   @map("student_uid") @db.VarChar(30)
  category            String   @db.VarChar(100)
  description         String   @db.Text
  evidence            String?  @db.Text
  status              String   @default("Open") @db.VarChar(15)
  assignedAuthorityId Int?     @map("assigned_authority_id")
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt           DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)

  @@index([studentUid], map: "idx_grievance_student")
  @@index([status], map: "idx_grievance_status")
  @@index([assignedAuthorityId], map: "fk_grievance_authority")
  @@map("grievance_ticket")
}

model LeaveSubstitution {
  leaveId             Int      @id @default(autoincrement()) @map("leave_id")
  absentFacultyId     Int      @map("absent_faculty_id")
  substituteFacultyId Int      @map("substitute_faculty_id")
  leaveDate           DateTime @map("leave_date") @db.Date
  type                String   @db.VarChar(15)

  @@index([absentFacultyId], map: "idx_leave_absent")
  @@index([leaveDate], map: "idx_leave_date")
  @@index([substituteFacultyId], map: "fk_leave_substitute")
  @@map("leave_substitution")
}

model NoticeBoard {
  noticeId       Int      @id @default(autoincrement()) @map("notice_id")
  title          String   @db.VarChar(255)
  targetAudience String   @map("target_audience") @db.VarChar(15)
  aiFilterTags   Json?    @map("ai_filter_tags")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamp(0)

  @@map("notice_board")
}

model LabBatch {
  batchId   Int    @id @default(autoincrement()) @map("batch_id")
  subjectId Int    @map("subject_id")
  batchName String @map("batch_name") @db.VarChar(20)
  facultyId Int    @map("faculty_id")

  @@unique([subjectId, batchName], map: "uq_subject_batch")
  @@index([facultyId], map: "fk_batch_faculty")
  @@map("lab_batch")
}

model Experiment {
  experimentId Int    @id @default(autoincrement()) @map("experiment_id")
  subjectId    Int    @map("subject_id")
  experimentNo Int    @map("experiment_no")
  title        String @db.VarChar(255)
  maxMarks     Int    @map("max_marks")

  @@unique([subjectId, experimentNo], map: "uq_experiment")
  @@map("experiment")
}

model LabSession {
  sessionId         Int      @id @default(autoincrement()) @map("session_id")
  subjectId         Int      @map("subject_id")
  batchId           Int      @map("batch_id")
  sessionDate       DateTime @map("session_date") @db.Date
  assignedFacultyId Int      @map("assigned_faculty_id")
  originalFacultyId Int?     @map("original_faculty_id")
  isSubstitute      Boolean  @default(false) @map("is_substitute")
  status            String   @default("Pending") @db.VarChar(15)

  @@index([subjectId, sessionDate], map: "idx_lab_session_subject_date")
  @@index([batchId], map: "fk_session_batch")
  @@index([assignedFacultyId], map: "fk_session_faculty")
  @@index([subjectId, sessionDate], map: "idx_lab_sess_date")
  @@map("lab_session")
}

model LabAttendance {
  attendanceId Int    @id @default(autoincrement()) @map("attendance_id")
  sessionId    Int    @map("session_id")
  studentUid   String @map("student_uid") @db.VarChar(30)
  status       String @db.VarChar(10)

  @@unique([sessionId, studentUid], map: "uq_lab_attendance")
  @@index([sessionId], map: "idx_lab_attendance_session")
  @@index([studentUid], map: "fk_lab_attendance_student")
  @@index([sessionId], map: "idx_lab_att_sess")
  @@map("lab_attendance")
}

model LabMark {
  markId         Int      @id @default(autoincrement()) @map("mark_id")
  studentUid     String   @map("student_uid") @db.VarChar(30)
  subjectId      Int      @map("subject_id")
  experimentId   Int      @map("experiment_id")
  sessionId      Int      @map("session_id")
  vivaMarks      Decimal? @map("viva_marks") @db.Decimal(5, 2)
  executionMarks Decimal? @map("execution_marks") @db.Decimal(5, 2)
  journalMarks   Decimal? @map("journal_marks") @db.Decimal(5, 2)
  totalMarks     Decimal? @map("total_marks") @db.Decimal(5, 2)
  remarks        String?  @db.Text
  updatedBy      Int?     @map("updated_by")
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)

  @@unique([studentUid, experimentId], map: "uq_lab_marks")
  @@index([studentUid], map: "idx_lab_marks_student")
  @@index([experimentId], map: "fk_lab_marks_experiment")
  @@index([updatedBy], map: "fk_lab_marks_faculty")
  @@index([sessionId], map: "fk_lab_marks_session")
  @@index([subjectId], map: "fk_lab_marks_subject")
  @@index([studentUid], map: "idx_lab_marks_stu")
  @@map("lab_marks")
}

model LabSubmission {
  submissionId Int      @id @default(autoincrement()) @map("submission_id")
  studentUid   String   @map("student_uid") @db.VarChar(30)
  experimentId Int      @map("experiment_id")
  fileUrl      String?  @map("file_url") @db.Text
  submittedAt  DateTime @default(now()) @map("submitted_at") @db.Timestamp(0)
  status       String?  @db.VarChar(15)

  @@index([experimentId], map: "fk_submission_experiment")
  @@index([studentUid], map: "fk_submission_student")
  @@map("lab_submission")
}

model AictePoints {
  recordId   Int      @id @default(autoincrement()) @map("record_id")
  studentUid String   @map("student_uid") @db.VarChar(30)
  activity   String   @db.VarChar(255)
  points     Int
  awardedBy  Int      @map("awarded_by")
  awardedAt  DateTime @default(now()) @map("awarded_at") @db.Timestamp(0)

  @@index([studentUid], map: "idx_aicte_student")
  @@index([awardedBy], map: "fk_aicte_faculty")
  @@index([studentUid], map: "idx_aicte_stu")
  @@map("aicte_points")
}

model TgAssignment {
  assignmentId Int    @id @default(autoincrement()) @map("assignment_id")
  facultyId    Int    @map("faculty_id")
  studentUid   String @map("student_uid") @db.VarChar(30)
  semester     Int

  @@unique([facultyId, studentUid, semester], map: "uq_tga")
  @@index([facultyId], map: "idx_tga_faculty")
  @@index([studentUid], map: "idx_tga_student")
  @@index([facultyId], map: "idx_tga_fac")
  @@index([studentUid], map: "idx_tga_stu")
  @@map("tg_assignment")
}
