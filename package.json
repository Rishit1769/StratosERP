{
  "name": "stratoserp",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "dev:web": "turbo dev --filter=@stratoserp/web",
    "dev:api": "turbo dev --filter=@stratoserp/api",
    "build": "turbo build",
    "build:web": "turbo build --filter=@stratoserp/web",
    "build:api": "turbo build --filter=@stratoserp/api",
    "lint": "turbo lint",
    "clean": "turbo clean",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "typecheck": "turbo typecheck"
  },
  "devDependencies": {
    "prettier": "^3.3.0",
    "turbo": "^2.5.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "npm@10.0.0"
}
